# PostgreSQL
DB_USER=realestate_user
DB_PASSWORD=changeme_strong_password
DB_NAME=realestate

# Constructed by docker-compose — do not set manually in compose context
DATABASE_URL=postgresql://realestate_user:changeme_strong_password@db:5432/realestate

# Express server
NODE_ENV=development
PORT=4000

# Census API (keyless — no token needed for public endpoints)
# 500 requests/day limit on unauthenticated access
CENSUS_API_BASE=https://api.census.gov/data/

# PgAdmin (optional)
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=admin

# Clerk Auth (Clerk Dashboard -> API Keys)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
